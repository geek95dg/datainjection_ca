<div class="card-header mx-5 mb-2">
    <h3 class="card-title d-flex align-items-center ">
        <span class="status rounded-1 me-1">
            <i class="ti ti-device-laptop"></i>
            {{ __('Model', 'datainjection') }} - {{ model_name }}
        </span>
        </h3>
</div>
<div class="card p-3 my-5"
     id="injection_container"
     data-batch-url="{{ batch_url }}"
     data-result-url="{{ result_url }}"
     data-model-id="{{ model_id }}"
     data-nblines="{{ nblines }}"
     data-batch-size="10"
     data-status-label="{{ __('Injection of the file', 'datainjection') }}"
     data-lines-label="{{ __(' lines', 'datainjection') }}"
     data-error-label="{{ __('Error', 'datainjection') }}"
>
    <div class="hr-text mt-5 mb-5">
        <i class="fa-2x ti ti-chart-bar"></i>
        <span>{{ __('Import progress', 'datainjection') }}</span>
    </div>
    <div class="progress" role="progressbar" aria-label="{{ __('Injection of the file', 'datainjection') }}" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" style="height: 20px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" style="width: 0%; height: 20px;">
            0%
        </div>
    </div>
    <div class="text-muted text-center mt-2" id="injection_status">
        {{ __('Injection of the file', 'datainjection') }} — 0 / {{ nblines }} {{ __(' lines', 'datainjection') }}
    </div>

    {# Hidden until the batch JS hits an error. Lets the user recover from
       a stuck import without reinstalling the plugin. #}
    <div id="injection_error" class="alert alert-danger mt-3" style="display:none;">
        <strong>{{ __('Import failed', 'datainjection') }}</strong>
        <div id="injection_error_message" class="mt-1 small text-break"></div>
        <div class="small text-muted mt-2">
            {{ __('Check /var/log/glpi/datainjection.log for the exception. Use the button below to clear the stuck session and start over.', 'datainjection') }}
        </div>
    </div>

    {# Always-available abort button. Posts cancel=1 to the legacy
       controller, which calls `PluginDatainjectionSession::removeParams()`
       to wipe the stuck-import state from the session and redirects back
       to the model picker. #}
    <form method="post" action="{{ form_action }}" class="mt-3 text-end">
        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}" />
        <input type="hidden" name="cancel" value="1" />
        <button type="submit" class="btn btn-outline-secondary">
            <i class="ti ti-x me-1"></i>
            {{ __('Abort and start over', 'datainjection') }}
        </button>
    </form>

<script src="{{ plugin_url }}js/injection_progress.js"></script>
<script>
    $(function() {
        startBatchInjection(document.getElementById('injection_container'));
    });
</script>